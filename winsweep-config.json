{
  "defaultProfile": "Safe",
  "thresholds": {
    "minFreeGB": 35,
    "minFreePercent": 18,
    "tempOlderThanDays": 1,
    "cacheOlderThanDays": 3,
    "logRetentionDays": 30,
    "perDrive": {
      "C:": {
        "minFreeGB": 35,
        "minFreePercent": 18
      }
    }
  },
  "paths": {
    "guardDrive": "C:",
    "extraPathsFile": "extra-cache-paths.txt",
    "logDir": "",
    "excludedPaths": []
  },
  "features": {
    "aggressiveSafe": false,
    "browserCaches": false,
    "appCaches": false,
    "spotifyCache": true,
    "discordCache": true,
    "telegramCache": true,
    "slackCache": false,
    "teamsCache": false,
    "zoomCache": false,
    "registry": true,
    "extraPaths": false,
    "developerCaches": false,
    "gameCaches": false,
    "clearRecycleBin": false,
    "notifyOnPressure": true
  },
  "schedule": {
    "guardStart": "00:15",
    "guardEveryHours": 3,
    "deepWeekly": "03:20",
    "deepDay": "Sunday"
  }
}
